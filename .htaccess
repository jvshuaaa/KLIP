# Block access to sensitive files (.env, .git, etc.)
<FilesMatch "^\.">
    Order allow,deny
    Deny from all
</FilesMatch>

# Block specific sensitive files
<FilesMatch "(^#.*#|\.(bak|config|dist|fla|inc|ini|log|psd|sh|sql|sw[op]|env|env\.local|gitignore|gitattributes|md))$">
    Order allow,deny
    Deny from all
</FilesMatch>

# Disable directory browsing
Options -Indexes

# Block access to sensitive directories
RedirectMatch 403 ^/(vendor|node_modules|storage|bootstrap|config|database|resources|routes|tests|backend|frontend)/.*$
